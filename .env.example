# ── Frontend (Vite) — copy to `.env` for local ──────────────────────────────
VITE_HOST=127.0.0.1
VITE_PORT=5173
VITE_BASE_URL=http://127.0.0.1:5173
VITE_PREVIEW_PORT=4173

# Backend origin (Vite /api proxy target + WebSocket upgrade)
VITE_BACKEND_URL=http://127.0.0.1:5000
VITE_API_PROXY_TARGET=http://127.0.0.1:5000

# Browser API base — prefer relative /api (proxy). Use full URL only if needed.
VITE_API_BASE=/api

# ── Production (Vercel) — set as Project Environment Variables ──────────────
# VITE_BASE_URL=https://job-finder-stream.vercel.app
# VITE_BACKEND_URL=https://job-finder-stream-backend.vercel.app
# VITE_API_BASE=https://job-finder-stream-backend.vercel.app/api
